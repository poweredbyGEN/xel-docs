---
const NAV = [
	{ label: 'Home', href: 'https://xel.xyz/' },
	{ label: 'Create', href: 'https://xel.xyz/create' },
	{ label: 'Providers', href: 'https://xel.xyz/providers' },
	{ label: 'Docs', href: '/', active: true },
];
---

<header class="xel-header">
	<div class="xel-pill">
		<a href="https://xel.xyz/" class="xel-pill-logo" aria-label="XEL home">
			<img src="/logo.svg" alt="XEL" />
		</a>

		<nav class="xel-pill-nav" aria-label="Main">
			{
				NAV.map((n) => (
					<a href={n.href} class:list={['xel-pill-link', { 'is-active': n.active }]}>
						{n.label}
					</a>
				))
			}
		</nav>

		<a href="https://xel.xyz/create" class="xel-pill-cta">
			Create
		</a>
	</div>
</header>

<style>
	.xel-header {
		position: fixed;
		inset-inline: 0;
		top: 0;
		z-index: var(--sl-z-index-navbar, 50);
		padding: 1rem clamp(0.75rem, 2vw, 1.5rem) 0;
		pointer-events: none;
	}
	.xel-pill {
		pointer-events: auto;
		display: flex;
		align-items: center;
		gap: 1rem;
		height: 3.25rem;
		max-width: 1240px;
		margin: 0 auto;
		padding: 0 0.5rem 0 1.15rem;
		border: 1px solid hsl(0 0% 100% / 0.12);
		border-radius: 9999px;
		background: hsl(0 0% 7% / 0.78);
		backdrop-filter: blur(18px);
		box-shadow: 0 14px 40px hsl(0 0% 0% / 0.28);
	}
	.xel-pill-logo {
		display: inline-flex;
		align-items: center;
		color: #fff;
		flex: 0 0 auto;
	}
	.xel-pill-logo img {
		display: block;
		width: auto;
		height: 1.35rem;
		filter: brightness(0) invert(1);
	}
	.xel-pill-nav {
		display: flex;
		align-items: center;
		gap: clamp(1rem, 2vw, 1.6rem);
		margin-inline: auto;
	}
	.xel-pill-link {
		position: relative;
		color: hsl(0 0% 78%);
		font-size: 0.9rem;
		font-weight: 600;
		text-decoration: none;
		white-space: nowrap;
		transition: color 0.16s ease;
	}
	.xel-pill-link:hover,
	.xel-pill-link.is-active {
		color: #fff;
	}
	.xel-pill-link.is-active::after {
		content: '';
		position: absolute;
		inset-inline: 15%;
		bottom: -0.62rem;
		height: 2px;
		border-radius: 999px;
		background: linear-gradient(90deg, #ff6ef4, #ffb534, #76ff9a);
	}
	.xel-pill-cta {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		height: 2.25rem;
		padding: 0 1.15rem;
		border-radius: 9999px;
		background: linear-gradient(135deg, #ff6ef4, #ffb534);
		color: #fff;
		font-size: 0.875rem;
		font-weight: 700;
		text-decoration: none;
		box-shadow: 0 2px 16px hsl(312 100% 70% / 0.26);
	}
	.xel-pill-cta:hover {
		filter: brightness(1.06);
	}
	@media (max-width: 50rem) {
		.xel-header {
			padding-top: 0.75rem;
		}
		.xel-pill {
			height: 3rem;
			padding-inline-end: 3.25rem;
		}
		.xel-pill-nav {
			display: none;
		}
		.xel-pill-cta {
			display: none;
		}
	}
</style>
